{
  "name": "angular-a2ui",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "watch": "ng build --watch --configuration development",
    "build": "wireit",
    "test": "wireit",
    "serve:ssr:angular": "node dist/angular/server/server.mjs",
    "serve:ssr:restaurant": "node dist/restaurant/server/server.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "clean": "wireit",
    "build:renderer": "yarn workspace @a2ui/web_core build && yarn workspace @a2ui/markdown-it build && yarn workspace @a2ui/angular build",
    "serve:agent:restaurant": "cd ../../agent/adk/restaurant_finder && uv run .",
    "demo:restaurant": "yarn build:renderer && concurrently -k -n \"AGENT,WEB\" -c \"magenta,blue\" \"yarn serve:agent:restaurant\" \"yarn start -- restaurant\"",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "private": true,
  "dependencies": {
    "@a2a-js/sdk": "^0.3.13",
    "@a2ui/markdown-it": "*",
    "@a2ui/web_core": "workspace:*",
    "@angular/cdk": "^21.2.5",
    "@angular/common": "^21.2.5",
    "@angular/compiler": "^21.2.5",
    "@angular/core": "^21.2.5",
    "@angular/forms": "^21.2.5",
    "@angular/google-maps": "^21.2.5",
    "@angular/material": "^21.2.5",
    "@angular/platform-browser": "^21.2.5",
    "@angular/platform-server": "^21.2.5",
    "@angular/router": "^21.2.5",
    "@angular/ssr": "^21.2.5",
    "@google/genai": "^2.8.0",
    "@modelcontextprotocol/ext-apps": "^1.7.4",
    "chart.js": "^4.5.1",
    "chartjs-plugin-datalabels": "^2.2.0",
    "excalibur": "0.32.0",
    "express": "^5.2.1",
    "markdown-it": "^14.2.0",
    "ng2-charts": "^10.0.0",
    "tslib": "^2.8.1",
    "uuid": "^14.0.0",
    "zod": "^3.25.76",
    "zone.js": "~0.16.2"
  },
  "devDependencies": {
    "@angular/build": "^21.2.5",
    "@angular/cli": "^21.2.5",
    "@angular/compiler-cli": "^21.2.5",
    "@types/express": "^5.0.6",
    "@types/jasmine": "^6.0.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.9.3",
    "@types/uuid": "^11.0.0",
    "@vitest/browser": "^4.1.8",
    "concurrently": "^10.0.3",
    "cypress": "^15.17.0",
    "eslint": "^10.4.1",
    "gts": "^7.0.0",
    "jasmine-core": "^6.3.0",
    "jsdom": "^29.1.1",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "^2.2.1",
    "karma-jasmine": "^5.1.0",
    "karma-jasmine-html-reporter": "^2.2.0",
    "ng-packagr": "^22.0.0",
    "playwright": "^1.60.0",
    "prettier": "^3.8.4",
    "sass": "^1.100.0",
    "tslib": "^2.8.1",
    "typescript": "5.9.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "wireit": "^0.15.0-pre.2"
  },
  "wireit": {
    "build": {
      "command": "ng build restaurant",
      "dependencies": [
        "../../../renderers/angular:build"
      ]
    },
    "test": {
      "command": "ng test --watch=false --browsers=ChromeHeadless",
      "dependencies": [
        "../../../renderers/angular:build"
      ],
      "files": [
        "src/**/*",
        "projects/**/*",
        "tsconfig.json"
      ]
    },
    "clean": {
      "command": "rm -rf dist .tsbuildinfo .wireit"
    }
  }
}

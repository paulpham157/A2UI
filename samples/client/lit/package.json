{
  "name": "@a2ui/lit-samples",
  "private": true,
  "version": "0.8.1",
  "description": "A2UI Lit Samples",
  "workspaces": [
    "shell"
  ],
  "scripts": {
    "serve:agent:restaurant": "cd ../../agent/adk/restaurant_finder && uv run .",
    "serve:shell": "yarn workspace @a2ui/shell dev",
    "build:renderer": "yarn workspace @a2ui/web_core build && yarn workspace @a2ui/markdown-it build && yarn workspace @a2ui/lit build",
    "demo:restaurant": "yarn build:renderer && concurrently -k -n \"SHELL,REST\" -c \"magenta,blue\" \"yarn serve:shell\" \"yarn serve:agent:restaurant\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "echo \"Workspace has no tests.\"",
    "lint": "echo \"Workspace has no lint configuration.\"",
    "lint:fix": "echo \"Workspace has no lint configuration.\""
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.13",
    "@a2ui/lit": "workspace:*",
    "@a2ui/markdown-it": "*",
    "@a2ui/web_core": "workspace:*",
    "@google/genai": "^2.8.0",
    "@lit-labs/signals": "^0.3.0",
    "@lit/context": "^1.1.6",
    "@types/node": "^25.9.3",
    "lit": "^3.3.3"
  }
}